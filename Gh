import os
from langchain_google_vertexai import ChatVertexAI, VertexAIEmbeddings

# 1. SETUP: Replace with the actual path to your JSON file
CREDENTIALS_PATH = "path/to/your/service-account-file.json"

if not os.path.exists(CREDENTIALS_PATH):
    print(f"❌ Error: File not found at {CREDENTIALS_PATH}")
else:
    # Set the environment variable so Google Cloud SDK can find it
    os.environ["GOOGLE_APPLICATION_CREDENTIALS"] = CREDENTIALS_PATH
    print("✅ Credentials path set successfully.")

# 2. TEST GEMINI LLM
try:
    print("\n--- Testing Gemini 2.5 Flash ---")
    llm = ChatVertexAI(
        model_name="gemini-2.5-flash",
        location="europe-west2",
        temperature=0,
        max_output_tokens=5000
    )
    
    # Simple test prompt
    response = llm.invoke("Say 'Credentials working' if you can read this.")
    print(f"🤖 Model Response: {response.content}")
    
except Exception as e:
    print(f"❌ LLM Test Failed: {e}")

# 3. TEST EMBEDDINGS (Critical for your RAG system)
try:
    print("\n--- Testing Vertex AI Embeddings ---")
    # Using the latest multimodal embedding model released March 2026
    embeddings = VertexAIEmbeddings(
        model_name="gemini-embedding-2-preview", 
        location="europe-west2"
    )
    
    test_vector = embeddings.embed_query("Testing my policy repository search.")
    print(f"📈 Embedding Successful! Vector length: {len(test_vector)}")
    print(f"First 5 dimensions: {test_vector[:5]}")
    
except Exception as e:
    print(f"❌ Embeddings Test Failed: {e}")
